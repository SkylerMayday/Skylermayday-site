# Copy this file to .env.local and fill in real values. .env.local is
# gitignored and never committed. See README.md for where each value comes
# from and how each env var is used.

# --- Twitch (Helix API, App Access Token via client_credentials) ---
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Numeric broadcaster/user id, resolved via GET /helix/users?login=<name>
TWITCH_BROADCASTER_ID=

# --- YouTube Data API v3 (read-only) ---
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# --- Resend (contact form email) ---
RESEND_API_KEY=
# Inbox that receives contact submissions
CONTACT_TO_EMAIL=
# Must be on a Resend-verified domain. Until skylermayday.com is verified,
# use Resend's sandbox sender: onboarding@resend.dev
CONTACT_FROM_EMAIL=

# --- Discord ("new submission" webhook ping) ---
DISCORD_WEBHOOK_URL=

# --- Tools page external link-out (Railway) ---
STREAM_ANALYSER_URL=

# --- PTCG Binders (optional — has a working default) ---
GITHUB_BINDERS_RAW_BASE=https://raw.githubusercontent.com/SkylerMayday/binders-pokedex-binder/main
